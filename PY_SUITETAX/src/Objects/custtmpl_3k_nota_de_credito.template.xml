<#setting locale="en_US">
<#setting number_format="#.##">
<?xml version="1.0"?>
<!DOCTYPE pdf PUBLIC "-//big.faceless.org//report" "report-1.1.dtd">
<pdf>
    
    <head>
    <#assign _currencysymbol = record.currencysymbol> 
    <#assign wordCurrency = ''> 
    <#if _currencysymbol?has_content>
    <#if _currencysymbol == 'PYG'>
        <#assign wordCurrency = 'GUARANÍES'>
    <#elseif _currencysymbol == 'USD'>
        <#assign wordCurrency = 'DÓLARES AMERICANOS'>
    </#if>
       </#if>
        <#if record.custbody_l595_tipo_comprobante.id='1' || record.custbody_l595_tipo_comprobante.id='2' || record.custbody_l595_tipo_comprobante.id='3' || record.custbody_l595_tipo_comprobante.id='4' || record.custbody_l595_tipo_comprobante.id='5' || record.custbody_l595_tipo_comprobante.id='6'>
            <macrolist>
                <macro id="nlheader">
                    <table class="header" style=" height: 35%; width: 100%; border: 2px solid black; ">
                        <tr>
                            <td colspan="9" align="center" style="text-align: center; background: #AEAEAE;">KuDE de Nota de crédito electrónica</td>
                        </tr>
                        <tr>
                            <td colspan="6" rowspan="4" align="left" style="margin-left: 13px;">
                              <#assign jsonList = record.custbody_l595_actividad_economica?eval />
                                <#assign actEconomica = jsonList[0].nombre />
                                <span class="title">
                                    <!-- <img src='https://7138551.app.netsuite.com/core/media/media.nl?id=112&amp;c=7138551&amp;h=0uZXyLZrVmHUHHqQHbpoR3jGoUNwqGBj_hqm-kdkTUjT6dLH' style="vertical-align: center; height:40%; width:40%" /> -->
                                    <#if subsidiary.logo?length != 0>
                                        <img src="${subsidiary.logo@url}" style="vertical-align: middle; height:98px; width:168px; margin-top: 8px;" />
                                    </#if>
                                    <p style="text-align: left;"><span style="font-size:11px;">
                                     <b> ${subsidiary.legalname} </b> <br />
                                      Dirección: ${subsidiary.mainaddress_text ?replace('\r\n',' ') ?replace('\n',' ') ?replace('<br />',' ')} <br />
                                      Ciudad: ${subsidiary.city} <br />
                                      Telefono: ${subsidiary.custrecord_l595_telefono}<br />
                                      Email: ${subsidiary.email}<br />
                                      Actividad Eco: ${actEconomica}
                                    </span></p>
                                </span>
                            </td>
                            <td colspan="3" rowspan="4" align="left" style="margin-top: 10px; font-size:11px;">
                                <p>
                                    RUC:${subsidiary.custrecord_l595_nro_ident_fiscal}<br />
                                    TIMBRADO N° ${record.custbody_l595_timbrado}<br />
                                    Fecha Inicio Vigencia: ${record.custbody_l56_ref_num.custrecord_l595_numerad_fecha_inicio}<br />
                                    Serie: ${record.custbody_l595_serie}
                                </p><br /><br />
                                <p>
                                    ${record.custbody_l595_tipo_comprobante}<br />
                                    ${record.custbody_l595_numero_localizado}
                                </p>
                            </td>
                        </tr>
                    </table>
                </macro>
                <macro id="nlfooter">
                    <table style="height: 15%; width: 100%;">
                    <#assign cdc = record.custbody_l595_fe_cdc_generado?if_exists?trim>
                    <#assign qrRaw = record.custbody_l595_fe_qr_generado?if_exists!''?trim>
                    <#if qrRaw?contains('href="')>
                      <#assign urlPart = qrRaw?keep_after('href="')?keep_before('"')?trim>
                    <#elseif qrRaw?contains('href=')>
                      <#assign urlPart = qrRaw?keep_after('href=')?keep_before('>')?trim>
                    <#else>
                      <#assign urlPart = qrRaw>
                    </#if>
                    <#assign urlClean = urlPart?replace('\r','')?replace('\n','')>
                  <tr>
                    <td colspan="3">
                      <#if qrRaw?has_content>
                        <barcode codetype="qrcode"
                                 showtext="false"
                                 width="150"
                                 height="150"
                                 value="${urlClean}"/>
                      <#else>
                    <img src="data:image/gif;base64,
                        R0lGODlhAQABAIAAAP///wAAACH5BAEAAAAALAAAAAABAAEAAAICRAEAOw=="
                         width="150" height="150" />
                      </#if>
                    </td>

                            <td colspan="6" align="center" style="margin-left: 13px; margin-top: 20px; font-size:11px; text-align: center;">
                                <span>
                                    Consulte la validez de este Documento Electrónico con el número de CDC impreso abajo en: https://ekuatia.set.gov.py/consultas/
                                </span> <br /><br />
                                <span><b>CDC: ${cdc?default('-')}</b></span>
                            </td>
                        </tr>
                    </table>
                    <table style="width: 100%;">
                        <tr>
                            <td style="font-size: 11px;">
                                <p><b>ESTE DOCUMENTO ES UNA REPRESENTACIÓN GRÁFICA DE UN DOCUMENTO ELECTRÓNICO (XML)</b>
                                    Información de interés del facturador electrónico emisor.
                                    Si su documento electrónico presenta algún error, podrá solicitar la modificación dentro de las 72 horas siguientes de la emisión de este comprobante.</p>
                            </td>
                        </tr>
                    </table>
                </macro>
            </macrolist>
        </#if>
        <style type="text/css">
            * {
                <#if .locale=="zh_CN">font-family: NotoSans, NotoSansCJKsc, sans-serif;
                <#elseif .locale=="zh_TW">font-family: NotoSans, NotoSansCJKtc, sans-serif;
                <#elseif .locale=="ja_JP">font-family: NotoSans, NotoSansCJKjp, sans-serif;
                <#elseif .locale=="ko_KR">font-family: NotoSans, NotoSansCJKkr, sans-serif;
                <#elseif .locale=="th_TH">font-family: NotoSans, NotoSansThai, sans-serif;
                <#else>font-family: NotoSans, sans-serif;
                </#if>
            }
            
            table {
                font-size: 7px;
                table-layout: fixed;
            }
            
            th {
                font-weight: bold;
                font-size: 8pt;
                vertical-align: middle;
                padding: 5px 6px 3px;
                background-color: #AEAEAE;
                color: #333333;
            }
            
            td {
                padding: 4px 6px;
            }

            td p {
                text-align: left
            }
            
            b {
                font-weight: bold;
            }
            
            ul li {
                font-size: 10pt;
            }
            
            table.header td {
                padding: 0;
                font-size: 11pt;
            }
            
            table.footer td {
                padding: 0;
                font-size: 8pt;
            }
            
            table.body td {
                padding-top: initial;
            }
            
            table.total {
                page-break-inside: avoid;
            }
            
            tr.totalrow {
                background-color: #e3e3e3;
                line-height: 200%;
            }
            
            td.totalboxtop {
                font-size: 12pt;
                background-color: #e3e3e3;
            }
            
            td.addressheader {
                font-size: 8pt;
                padding-top: 6px;
                padding-bottom: 2px;
            }
            
            td.address {
                padding-top: 0;
            }
            
            td.totalboxmid {
                font-size: 28pt;
                padding-top: 20px;
                background-color: #e3e3e3;
            }
            
            td.totalboxbot {
                background-color: #e3e3e3;
                font-weight: bold;
            }
            
            span.title {
                font-size: 28pt;
            }
            
            span.number {
                font-size: 16pt;
            }
            
            span.itemname {
                font-weight: bold;
                line-height: 150%;
            }
            
            hr {
                width: 100%;
                color: #d3d3d3;
                background-color: #d3d3d3;
                height: 1px;
            }
        </style>
    </head>

    <body header="nlheader" header-height="27%" footer="nlfooter" footer-height="20%" padding="0.5in 0.5in 0.5in 0.5in" size="A4">
        <#if record.custbody_l595_tipo_comprobante.id='1' || record.custbody_l595_tipo_comprobante.id='2' || record.custbody_l595_tipo_comprobante.id='3' || record.custbody_l595_tipo_comprobante.id='4' || record.custbody_l595_tipo_comprobante.id='5' || record.custbody_l595_tipo_comprobante.id='6'>
            <table class="header" style="height: 66px; width: 100%; border: 2px solid black;">
                <tr style="margin-top: 10px;">
                    <td align="left" style="width: 60%;">
                        <p style="text-align: left; font-size:12px;"><span style="font-size:12px;">
                &nbsp;</span>Nombre o Razón social: ${record.custbody_l595_razon_social}</p>
                    </td>
                    <td align="left" style="width: 40%;">
                        <p style="text-align: left; font-size:12px;"><span style="font-size:12px;">
                &nbsp;Fecha y Hora emsión: ${record.trandate} 00:00:00</span></p>
                    </td>
                </tr>
                <tr>
                    <td align="left" style="width: 60%;">
                        <p style="text-align: left; font-size:12px;"><span style="font-size:12px;">
                &nbsp;Ruc / Documento de Identidad: ${record.custbody_l595_nro_documento}</span></p>
                    </td>
                    <td align="left" style="width: 60%;">
                        <p style="text-align: left; font-size:12px;"><span style="font-size:12px;">
                &nbsp;Dirección: ${record.billingaddress.addr1} </span></p>
                    </td>
                </tr>
                <tr>
                    <td align="left" style="width: 40%;">
                        <p style="text-align: left; font-size:12px;"><span style="font-size:12px;">
                &nbsp;Moneda: ${record.custbody_l595_simbolo_moneda}</span>&nbsp; &nbsp;Tipo De Cambio: ${record.exchangerate}</p>
                    </td>
                    <td colspan="2" align="left" style="width: 40%;">
                        <p style="text-align: left; font-size:12px;"><span style="font-size:12px;">
                &nbsp;Telefono: ${record.billingaddress.addrphone}</span></p>
                    </td>
                </tr>
                <tr>
                    <td align="left" style="width: 40%;">
                        <p style="text-align: left; font-size:12px;"><span style="font-size:12px;">
                &nbsp;Tipo de transacción: ${record.custbody_l595_tipo_transaccion}</span></p>
                    </td>
                    <td colspan="2" align="left" style="width: 40%;">
                        <p style="text-align: left; font-size:12px;"><span style="font-size:12px;">
                &nbsp;Email: ${record.entity.email}</span></p>
                    </td>
                </tr>
                <tr>
                  <#if record.createdfrom!=''>
                    <td colspan="2" align="left" style="width: 60%;">
                       <p style="text-align: left; font-size:12px;"><span style="font-size:12px;">
                &nbsp;Documento Asociado: ${record.createdfrom.custbody_l595_fe_cdc_generado} </span></p> 
                            
                        
                    </td>
                  <#else>
                    <td  colspan="2" align="left" style="width: 60%;">
                        <p style="text-align: left; font-size:12px;"><span style="font-size:12px;">
                &nbsp;Documento Asociado: ${record.custbody_l595_cdc_doc_ref}  </span></p>
                       

                    </td>
                  </#if>
                </tr>
            </table>
            <#if record.custbody_l595_tipo_comprobante.id='2' || record.custbody_l595_tipo_comprobante.id='5'>
                <p style="text-align: left; font-size:12px; "><i>Sirva(se) tomar nota que estamos DEBITANDO en su apreciable Cuenta Corriente, por las razones siguientes:</i></p>
            </#if>
            <#if record.item?has_content>
              
            <#assign totalImpuestoExento=0>
            <#assign totalImpuesto5=0>
            <#assign totalImpuesto10=0>
            <#assign totalIva5=0>
            <#assign totalIva10=0>
            <#assign descuentoTotal=0>
            <#assign descuentoTotalFinal=0>
            <#assign descuentoTotalItem=0>
                <table class="itemtable" style="width: 100%; margin-top: 13px; border: 1px solid black;">
                    <!-- start items -->
                    <#list record.item as item>
                    <#assign taxcode=item.custcol_l595_codigo_impuesto.internalid>
                        <#if (item.quantity?has_content)>
                            <#assign cantidad=item.quantity>
                        <#else>
                            <#assign cantidad=1>
                        </#if>

                            <#if item_index==0>
                                <tr>
                                    <td align="center" style="width: 13%; font-size: 9px; border: 1px solid black;"><b>COD</b></td>
                                    <td align="center" style="width: 17%; font-size: 9px; border: 1px solid black;"><b>Descripción</b></td>
                                    <td align="center" style="width: 7%; font-size: 9px; border: 1px solid black;"><b>U.M.</b></td>
                                    <td align="center" style="width: 10%; font-size: 9px; border: 1px solid black;"><b>Cantidad</b></td>
                                    <td align="center" style="width: 15%; font-size: 9px; border: 1px solid black;"><b>Precio Unitario</b> </td>
                                    <td align="center" style="width: 17%; font-size: 9px; border: 1px solid black;"><b>Descuento/Anticipo</b></td>
                                    <td align="center" style="width: 10%; font-size: 9px; border: 1px solid black;"><b>Exentas</b></td>
                                    <td align="center" style="width: 10%; font-size: 9px; border: 1px solid black;"><b>5%</b></td>
                                    <td align="center" style="width: 13%; font-size: 9px; border: 1px solid black;"><b>10%</b></td>
                                </tr>
                            </#if>
                            <#if item.itemtype!='Discount' && item.amount \gt 0 >
                                <tr>
                                    <td align="left" style="width: 13%; font-size: 10px; border: 1px solid black;">${item.custcol_l595_cod_int}</td>
                                    <td align="right" style="width: 17%; font-size: 10px; border: 1px solid black;">${item.description}</td>
                                    <td align="left" style="width: 7%; font-size: 10px; border: 1px solid black;">${item.custcol_l595_unidad_medida_imp}</td>
                                    <td align="right" style="width: 10%; font-size: 10px; border: 1px solid black;">${item.quantity},00</td>
                                    
                                        <!-- calcular descuento Rate  -->
                                               <#assign rawRate = record.discountrate?abs?number>
                                                <#if rawRate \gt 1>
                                                    <#assign totalDiscount = rawRate>
                                                  <#assign rateGlobal = totalDiscount?number / record.subtotal?number>
                                                <#else>
                                                <#assign rateGlobal   = rawRate>  
                                                  <#assign totalDiscount = record.subtotal?number * rateGlobal>
                                                </#if>

                                 <#if item.rate \gt 0>
                                 <#assign rate = item.rate?c?number>
                                 <#else>
                                 <#assign rate = (item.amount?c?number / item.quantity)?c?number>
                                 </#if>
                                 <#assign E721 = rate * (1 + item.custcol_l595_tasa_imp_art)>

                                 <#assign taxWithoutDiscountPerUnit = item.custcol_l595_tasa_imp_art?c?number * item.amount>
                                   <#assign taxWithtDiscountPerUnit = taxWithoutDiscountPerUnit * record.discountrate>
                                     <#assign unitPriceWithTax= (item.amount?c?number / item.quantity) * (1 + item.custcol_l595_tasa_imp_art) >
                                    <td align="right" style="width: 35%; font-size: 10px; border: 1px solid black;">${unitPriceWithTax?string(",###")?replace(",",".")}</td>
                                    <#if (item.custcol_l595_descuento?has_content && item.custcol_l595_descuento \gt 0)  && record.discountitem?has_content>
                                        <!-- <#assign EA004 = (E721) * rateGlobal>
                                        <#assign EA002 =   (E721 - EA004) * (item.custcol_l595_tasa_imp_art)> -->

                                        <#assign discountLine = item.custcol_l595_descuento/item.quantity>
                                        <#assign taxLineDiscount = discountLine * item.custcol_l595_tasa_imp_art>
                                        <#assign discountLineWithTax = (discountLine + taxLineDiscount)>
                                        <#assign EA004Withdiscountline = (E721 - discountLineWithTax) * rateGlobal>
                                        <#assign EA004 = E721 * rateGlobal>
                                        <#assign EA002 = discountLineWithTax + EA004Withdiscountline - EA004>



                                        <#assign descuentoTotal=   (EA004 + EA002) * item.quantity?number>
                                       <#assign descuentoTotalFinal=descuentoTotalFinal?number+descuentoTotal?number>
                                        <td align="right" style="width: 15%; font-size: 10px; border: 1px solid black;">${descuentoTotal?string(",###")?replace(",",".")}</td>
                                    <#elseif item.custcol_l595_descuento?has_content && item.custcol_l595_descuento \gt 0>
                                        <#assign descuentoTotal=item.custcol_l595_descuento * (1 + item.custcol_l595_tasa_imp_art) >
                                        <#assign descuentoTotalFinal=descuentoTotalFinal?number+descuentoTotal?number>
                                        <td align="right" style="width: 15%; font-size: 10px; border: 1px solid black;">${descuentoTotal?number?string(",###")?replace(",",".")}</td>
                                    <#elseif record.discountrate?has_content>
                                        <#assign descuentGlobal=record.discountrate?replace('%', '')?replace('-', '')?trim>
                                      <#assign EA004 = E721 * rateGlobal > 
                                        <#assign descuentoTotal= EA004 * item.quantity?number>
                                        <#assign descuentoTotalFinal=descuentoTotalFinal?number+descuentoTotal?number>
                                          <td align="right" style="width: 15%; font-size: 10px; border: 1px solid black;"> ${descuentoTotal?string(",###")?replace(",",".")}</td>
                                    </#if>

                                    <#assign amount=item.amount?replace('PYG', '')?trim>
                                    <#assign itemDiscount=item.custcol_l595_descuento?replace('PYG', '')?trim>

                                    <#assign totalConDescuento = (unitPriceWithTax?number * item.quantity?number) - descuentoTotal?number >
                                    <#if taxcode="157" || taxcode="158">
                                        <td align="right" style="width: 10%; font-size: 10px; border: 1px solid black;">${totalConDescuento?string(",###")?replace(",",".")}</td>
                                        <#assign totalImpuestoExento=totalImpuestoExento+totalConDescuento>
                                    <#else>
                                        <td align="right" style="width: 10%; font-size: 10px; border: 1px solid black;">0</td>
                                    </#if>
                                    <#if taxcode="156">
                                        <td align="right" style="width: 10%; font-size: 10px; border: 1px solid black;">${totalConDescuento?string(",###")?replace(",",".")}</td>
                                        <#assign totalImpuesto5=totalImpuesto5+totalConDescuento>
                                        <#assign totalIva5=totalIva5+item.taxamount?round>
                                    <#else>
                                        <td align="right" style="width: 10%; font-size: 10px; border: 1px solid black;">0</td>
                                    </#if>
                                    <#if taxcode="153">
                                        <td align="right" style="width: 10%; font-size: 10px; border: 1px solid black;">${totalConDescuento?string(",###")?replace(",",".")}</td>
                                        <#assign totalImpuesto10=totalImpuesto10+totalConDescuento>
                                        <#assign totalIva10=totalIva10+item.taxamount?round>
                                    <#else>
                                        <td align="right" style="width: 10%; font-size: 10px; border: 1px solid black;">0</td>
                                    </#if>
                                </tr>
                            <#elseif item.itemtype='Discount'>
                                <#if taxcode="8">
                                    <#assign totalIva5=totalIva5+item.taxamount>
                                </#if>
                                <#if taxcode="9">
                                    <#assign totalIva10=totalIva10+item.taxamount>
                                </#if>
                            </#if>
                    </#list>
                    <tr>
                        <td colspan="3" align="left" style="width: 10%; font-size: 10px; border-top: 1px solid black; border-left: 1px solid black; border-bottom: 1px solid black;">Subtotal</td>
                        <td colspan="3" align="left" style="width: 10%; font-size: 10px; border-top: 1px solid black; border-right: 1px solid black; border-bottom: 1px solid black;">&nbsp;</td>
                    
                        <td colspan="1" align="right" style="width: 10%; font-size: 10px; border: 1px solid black;">${totalImpuestoExento?string(",###")?replace(",",".")}</td>
                        <td colspan="1" align="right" style="width: 10%; font-size: 10px; border: 1px solid black;">${totalImpuesto5?string(",###")?replace(",",".")}</td>
                        <td colspan="1" align="right" style="width: 10%; font-size: 10px; border: 1px solid black;">${totalImpuesto10?string(",###")?replace(",",".")}</td>
                    </tr>
                    <tr>
                        <td colspan="4" align="left" style="width: 10%; font-size: 10px; border-top: 1px solid black; border-left: 1px solid black; border-bottom: 1px solid black;">Total Descuento</td>
                        <td colspan="4" align="left" style="width: 10%; font-size: 10px; border-top: 1px solid black; border-right: 1px solid black; border-bottom: 1px solid black;">&nbsp;</td>
                        <td colspan="1" align="right" style="width: 10%; font-size: 10px; border: 1px solid black;">${descuentoTotalFinal?number?string(",###")?replace(",",".")}</td>
                    </tr>
                    <tr>
                        <td colspan="4" align="left" style="width: 10%; font-size: 10px; border-top: 1px solid black; border-left: 1px solid black; border-bottom: 1px solid black;">Total Operación</td>
                        <td colspan="4" align="left" style="width: 10%; font-size: 10px; border-top: 1px solid black; border-right: 1px solid black; border-bottom: 1px solid black;">&nbsp;</td>
                        <#assign total=record.total?replace('PYG', '')?trim>
                        <td colspan="1" align="right" style="width: 10%; font-size: 10px; border: 1px solid black;">${total?number?string(",###")?replace(",",".")}</td>
                    </tr>
                    <tr>
                        <td colspan="6" align="left" style="width: 10%; font-size: 10px; border-top: 1px solid black; border-left: 1px solid black; border-bottom: 1px solid black;">${wordCurrency} ${record.custbody_l595_monto_escrito}</td>
                        <td colspan="2" align="left" style="width: 10%; font-size: 10px; border-top: 1px solid black; border-right: 1px solid black; border-bottom: 1px solid black;">&nbsp;</td>
                        <td colspan="1" align="right" style="width: 10%; font-size: 10px; border: 1px solid black;"></td>
                    </tr>
                    <#if _currencysymbol != 'PYG'>
                    <tr>
                        <td colspan="8" align="left" style="width: 10%; font-size: 10px; border: 1px solid black;">Total de la Operacion en Guaranies</td>
                         <#assign totalGuaranies = record.total * record.exchangerate>
                        <td colspan="1" align="right" style="width: 10%; font-size: 10px; border: 1px solid black;">${totalGuaranies?number?string(",###")?replace(",",".")}</td>
                    </tr>
                    </#if>
                    <tr>
                        <td colspan="9" align="center" style="width: 10%; font-size: 10px; border: 1px solid black;">Liquidación IVA: (5%) ${totalIva5?string(",###")?replace(",",".")}  (10%) ${totalIva10?string(",###")?replace(",",".")}  Total IVA: ${(totalIva10+totalIva5)?string(",###")?replace(",",".")}</td>
                    </tr>
                </table>
                <!--<#elseif record.custbody_l595_tipo_comprobante.id='3'>
                    <table class="itemtable" style="width: 100%;  border: 0px solid rgb(0, 0, 0);  margin-top: 10px; ">

                        <tr>
                            <td colspan="9" align="left" style="width: 71.5%; font-size: 10px; border: 0px solid black;"><b>MOTIVOS DE LA XXXXXXX</b></td>
                            <td align="right" style="width: 13.5%; font-size: 10px; border: 0px solid black;"><b></b></td>
                            <td align="center" style="width: 15%; font-size: 10px; border: 0px solid black;"><b></b></td>
                        </tr>
                    </table>

                    <table class="itemtable" style="height: 50px; width: 100%;  border: 0px solid rgb(0, 0, 0);">
